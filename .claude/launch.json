{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter (Android)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "android"],
      "port": 8080
    },
    {
      "name": "Flutter (iOS)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "ios"],
      "port": 8080
    },
    {
      "name": "Flutter (macOS)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "macos"],
      "port": 8080
    },
    {
      "name": "Flutter (Web)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "5000"],
      "port": 5000
    }
  ]
}
