<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>Jippymart Customer</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>jippymart_customer</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- ================= PERMISSIONS ================= -->
	<!-- 
		All permissions are requested only after user action (e.g., tapping camera button, selecting location).
		No permissions are requested on app launch.
	-->

	<!-- Location: Required for finding nearby restaurants and calculating delivery distance -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>JippyMart needs your location to show nearby restaurants and calculate accurate delivery distance and charges.</string>

	<!-- Location Always: Required because code checks for always permission (even though only when-in-use is requested) -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>JippyMart needs your location to show nearby restaurants and calculate accurate delivery distance and charges.</string>

	<!-- Camera: Required for taking photos (profile picture, order reviews, chat) -->
	<key>NSCameraUsageDescription</key>
	<string>JippyMart needs camera access to take photos for your profile picture, order reviews, and chat messages.</string>

	<!-- Photo Library: Required for selecting images from gallery -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>JippyMart needs access to your photos to select images for your profile picture, order reviews, and chat messages.</string>

	<!-- Photo Library Add: Required if saving images (optional, but kept for future features) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>JippyMart needs permission to save images to your photo library when you choose to save them.</string>

	<!-- Notifications: Required for push notifications (order updates, offers) -->
	<!-- Note: NSUserNotificationUsageDescription is deprecated for iOS 10+ but kept for backward compatibility -->
	<key>NSUserNotificationUsageDescription</key>
	<string>JippyMart sends notifications about your order status, delivery updates, and special offers.</string>

	<!-- Network -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>

	<!-- Google Maps / Platform Views -->
	<key>io.flutter.embedded_views_preview</key>
	<true/>

	<!-- iPad Support -->
	<key>UIRequiresFullScreen</key>
	<false/>
	
	<!-- ================= DEEP LINKING CONFIGURATION ================= -->
	
	<!-- URL Schemes: Custom scheme for deep linking (jippymart://) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.jippymart.customerapp</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>jippymart</string>
				<string>paytmoblKKV54729841220347</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.facebook.sdk</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fb640838582128923</string>
			</array>
		</dict>
	</array>

	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>paytm</string>
		<string>paytmmp</string>
		<string>phonepe</string>
		<string>tez</string>
	</array>

	<!-- Facebook App Events -->
	<key>FacebookAppID</key>
	<string>640838582128923</string>
	<key>FacebookClientToken</key>
	<string>qTBqYZbLtSkKFXP5YaVxhxx9fGg</string>
	<key>FacebookDisplayName</key>
	<string>JippyMart</string>
	<key>FacebookAutoLogAppEventsEnabled</key>
	<true/>
	<key>FacebookAdvertiserIDCollectionEnabled</key>
	<true/>

	<!-- Universal Links: Associated Domains for HTTPS deep links -->
	<!-- Note: The actual Associated Domains capability must be added in Xcode -->
	<!-- and the entitlements file must reference applinks:jippymart.in -->

</dict>
</plist>
